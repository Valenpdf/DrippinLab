@* Estructura base de navegación y diseño (Layout) del proyecto. *@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Drippin Lab</title>
    
    @* Vinculación de recursos de estilo fundamentales y librerías externas. *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Drippin.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
</head>
<body>

    <header>
        @* Barra de navegación principal con soporte para scroll dinámico. *@
        <nav id="main-header" class="navbar navbar-expand-lg navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3"
             style="background-color: black">

            <div class="container-fluid d-flex align-items-center">

                @* Control de activación para el menú lateral (Offcanvas) en dispositivos móviles. *@
                <button class="navbar-toggler me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* Despliegue de accesos directos por categoría para resoluciones de escritorio. *@
                <div class="d-none d-lg-flex align-items-center flex-row" id="categoria-iconos">
                    @if (ViewBag.Categorias != null)
                    {
                            @foreach (var categoria in ViewBag.Categorias)
                            {
                                    <a class="nav-link p-2"
                                       asp-controller="Categorias"
                                       asp-action="Details"
                                       asp-route-id="@categoria.CategoriaId"
                                       title="@categoria.CatNombre">
                                        <img src="@Url.Content(ImageHelper.FormatearRuta(categoria.CatICO))" alt="Icono de @categoria.CatNombre" class="categoria-icono-header" />
                                    </a>
                            }
                    }
                </div>

                @* Centro de identidad visual y navegación al inicio. *@
                <div class="text-center mx-auto" id="titulo-container">
                    <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                        <img src="/images/drippintitle.png" alt="DRIPPIN" class="logo-header">
                    </a>
                </div>
                 
                @* Acceso persistente al recurso de carrito de compras. *@
                <div class="d-flex order-3">
                    <ul class="navbar-nav flex-row">
                        <li class="nav-item me-3">
                                <a class="nav-link text-white" asp-controller="Carritos" asp-action="Index">
                                    <img src="~/images/carrito.png" alt="Carrito" class="carrito-icono" />
                                </a>
                        </li>
                    </ul>
                </div>

                @* 
                   Sistema de gestión de identidad de usuario (Dropdown).
                   Renderiza dinámicamente opciones basadas en el estado de autenticación y roles asignados.
                *@
                <div class="ms-auto me-3">
                    <div class="dropdown">
                        @* Disparador del menú de usuario con icono de identidad. *@
                        <button class="btn btn-link text-white dropdown-toggle" 
                                type="button" 
                                id="userDropdown" 
                                data-bs-toggle="dropdown" 
                                aria-expanded="false"
                                style="font-size: 1.5rem;">
                            <i class="fa-solid fa-circle-user"></i> 
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            @if (User.Identity.IsAuthenticated)
                            {
                                    @* Información de bienvenida y estado de sesión activa. *@
                                    <li>
                                        <span class="dropdown-item-text fw-bold text-primary">
                                            Hola, @User.Identity.Name!
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                
                                    @* Acceso restringido al Panel de Administración basado en políticas de rol. *@
                                    @if (User.IsInRole("Administrador"))
                                    {
                                            <li>
                                                <a class="dropdown-item" asp-controller="Inicio" asp-action="PanelAdmin">
                                                    <i class="fa-solid fa-shield-halved me-2"></i> Panel de Administrador
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                    }
                
                                    @* Terminación de la sesión actual de usuario. *@
                                    <li>
                                        <form asp-controller="Accesos" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fa-solid fa-right-from-bracket me-2"></i> Cerrar Sesión
                                            </button>
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </li>                  
                            }
                            else
                            {
                                    @* Opciones de entrada para usuarios no autenticados. *@
                                    <li>
                                        <a class="dropdown-item" asp-controller="Accesos" asp-action="Login">
                                            <i class="fa-solid fa-right-to-bracket me-2"></i> Iniciar Sesión
                                        </a>
                                    </li>
                
                                    <li>
                                        <a class="dropdown-item" asp-controller="Accesos" asp-action="Registrarse">
                                            <i class="fa-solid fa-user-plus me-2"></i> Registrarse
                                        </a>
                                    </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        @* 
           Menú lateral (Offcanvas) para la exploración de categorías. 
           Optimizado para la navegación táctil en dispositivos móviles. 
        *@
        <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Categorías</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
                    @if (ViewBag.Categorias != null)
                    {
                        @foreach (var categoria in ViewBag.Categorias)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Categorias" asp-action="Details" asp-route-id="@categoria.CategoriaId">
                                    <div class="cat-img">
                                        <img src="@Url.Content(ImageHelper.FormatearRuta(categoria.CatICO))" alt="Icono de @categoria.CatNombre" class="categoria-icono me-2" />
                                    </div>
                                    @categoria.CatNombre
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </header>

    @* Punto de inyección dinámico para el contenido específico de las vistas. *@
    <div class="contenido">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Carga de librerías de cliente fundamentales y scripts de aplicación. *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        @* 
           Orquestación de la reducción visual del encabezado (Header Collapse). 
           Modifica las clases del body para disparar transiciones de estilo al superar un umbral de scroll. 
        *@
        window.addEventListener("scroll", function () {
            const body = document.body;
            const html = document.documentElement;
            const scrolled = window.scrollY || html.scrollTop || body.scrollTop;

            if (scrolled > 42) {
                document.body.classList.add("header-small");
            } else {
                document.body.classList.remove("header-small");
            }
        });
    </script>
</body>
</html>
