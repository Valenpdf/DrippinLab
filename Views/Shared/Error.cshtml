@model ErrorViewModel
@{
    ViewData["Title"] = "Error del Sistema";
}

<h1 class="text-danger">Excepción Detectada</h1>
<h2 class="text-danger">Se ha producido un error crítico durante el procesamiento de la solicitud.</h2>

@* Visualización del identificador único de la solicitud para su rastreo en los logs del servidor. *@
@if (Model.ShowRequestId)
{
    <p class="text-white">
        <strong>ID de Solicitud (Correlation ID):</strong> <code>@Model.RequestId</code>
    </p>
}

<div class="text-white">
    <h3>Modo de Depuración</h3>
    <p>
        La activación del entorno de <strong>Desarrollo</strong> permite visualizar detalles técnicos extendidos sobre la excepción ocurrida.
    </p>
    @* Advertencia de seguridad sobre la exposición de trazas de error en entornos de producción. *@
    <p>
        <strong>El entorno de Desarrollo no debe habilitarse en aplicaciones desplegadas.</strong>
        La exposición de trazas de excepción puede revelar información sensible de la arquitectura del sistema.
    </p>
</div>
