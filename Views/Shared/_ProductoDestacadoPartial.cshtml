@model Drippin.Models.Producto

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css" />

<link rel="stylesheet" href="~/css/swiper.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/cards.css" asp-append-version="true" />

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<div class="contenedor-destacado">
    @* Componente de visualización dinámica (Swiper) para la galería de imágenes del producto. *@
    <div class="swiper swiper-destacado">
        <div class="swiper-wrapper">
            @* Renderización condicional de recursos visuales basada en la disponibilidad de rutas en el modelo. *@
            @if (!string.IsNullOrEmpty(Model.proImagen))
            {
                <div class="swiper-slide">
                    <img src="@Url.Content(ImageHelper.FormatearRuta(Model.proImagen))" alt="Producto: @Model.proNombre">
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.proImagen2))
            {
                <div class="swiper-slide">
                    <img src="@Url.Content(ImageHelper.FormatearRuta(Model.proImagen2))" alt="Producto: @Model.proNombre">
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.proImagen3))
            {
                <div class="swiper-slide">
                    <img src="@Url.Content(ImageHelper.FormatearRuta(Model.proImagen3))" alt="Producto: @Model.proNombre">
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.proImagen4))
            {
                <div class="swiper-slide">
                    <img src="@Url.Content(ImageHelper.FormatearRuta(Model.proImagen4))" alt="Producto: @Model.proNombre">
                </div>
            }
        </div>

        @* Controles de navegación y paginación para la interfaz de usuario. *@
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-pagination"></div>
    </div>


    <div class="info-producto">
        <h5 class="titulo-producto">@Model.proNombre.ToUpper()</h5>
        <div class="precio">$@Model.proPrecio.ToString("N2")</div>
        
        <div class="descripcion">            
            

            
                @* Indicador visual para productos con estatus de alta prioridad (Destacado). *@
                @if (Model.EsDestacado == true)
                {
                    <div class="descripcion-destacado">
                        <p>Destacado</p> 
                    </div>
                }
            

            <div class="descripcion-texto">
                @if (!string.IsNullOrEmpty(Model.proDescripcion))
                {
                    <p>
                        @Model.proDescripcion
                    </p>
                }
            </div>

            <div class="descripcion-medidas">
                @if (!string.IsNullOrEmpty(Model.proMedidas))
                {
                    <p>@Model.proMedidas</p>
                }
            </div>

        </div>

        <form asp-controller="Carritos" asp-action="AgregarAlCarrito" method="post">
    
            @* Inyección del identificador único del producto para el procesamiento de la orden en el servidor. *@
            <input type="hidden" name="proId" value="@Model.proId" />
    
            <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="fa-solid fa-cart-plus me-2"></i> Agregar al Carrito
            </button>
        </form>
    </div>

</div>
    


<script>
    @* 
       Inicialización y configuración del motor de carrusel Swiper. 
       Define parámetros de navegación, autoplay y responsividad (breakpoints). 
    *@
    const swiper = new Swiper('.swiper-destacado', {
      direction: 'horizontal',
      slidesPerView: 1,
      spaceBetween: 10,
      autoplay: {
        delay: 3000, 
        disableOnInteraction: false 
        },
      loop: true,

      pagination: {
        el: '.swiper-pagination',
      },

      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },

      scrollbar: {
        el: '.swiper-scrollbar',
      },

      breakpoints: {
          768: {
              slidesPerView: 2,
              spaceBetween: 10,
          },
      },
    });
</script>
