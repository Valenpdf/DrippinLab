@model Drippin.Models.Categoria
@* Vista retornada por: CategoriasController.Details *@
@{
    ViewData["Title"] = @Model.CatNombre;
}

<link rel="stylesheet" href="~/css/site.css" />

@* Integración de recursos externos para la funcionalidad de carruseles (Swiper). *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

@* Estilos específicos para el componente Swiper y la presentación de productos. *@
<link rel="stylesheet" href="~/css/swiper.css" />
<link rel="stylesheet" href="~/css/cards.css" />

<div class="barra-marquee">
    <div class="marquee-contenido">
        <span>🔥 Nueva colección ya disponible 🔥 &nbsp;&nbsp;&nbsp; | &nbsp;&nbsp;&nbsp; 💧 Envíos gratis en compras mayores a $30.000 💧 &nbsp;&nbsp;&nbsp; | &nbsp;&nbsp;&nbsp; 💥 ¡Seguinos en Instagram @@drippin.lab! 💥</span>
    </div>
</div>

<div class="container mt-3">
    <h2 class="text-white mb-4 categoria-titulo">@Model.CatNombre</h2>
</div>

@* Bloque de herramientas para el filtrado dinámico de la colección de productos. *@
<div class="barra-filtros">
    <button class="boton-filtro" onclick="toggleMenu()">Filtrar ▼</button>
    <div id="menu-filtros" class="menu-filtros oculto">
        <ul>
            <li><a asp-controller="Categorias" asp-action="Details" asp-route-id="@Model.CategoriaId" asp-route-sortBy="precio_asc">Precio ascendente</a></li>
            <li><a asp-controller="Categorias" asp-action="Details" asp-route-id="@Model.CategoriaId" asp-route-sortBy="precio_desc">Precio descendente</a></li>
            <li><a asp-controller="Categorias" asp-action="Details" asp-route-id="@Model.CategoriaId" asp-route-sortBy="nombre_asc">Nombre A-Z</a></li>
            <li><a asp-controller="Categorias" asp-action="Details" asp-route-id="@Model.CategoriaId" asp-route-sortBy="nombre_desc">Nombre Z-A</a></li>
            <li><a asp-controller="Categorias" asp-action="Details" asp-route-id="@Model.CategoriaId" >Reestablecer Orden</a></li>
        </ul>
    </div>
</div>

<section class="contenedor-productos">

    @* Validación de existencia de productos asociados a la categoría actual. *@
    @if (Model.Productos != null && Model.Productos.Any())
    {
        @* Iteración sobre la colección de productos para su renderización individual. *@
        @foreach (var p in Model.Productos)
        {
            <div class="card-producto">
                <a asp-controller="Productos" asp-action="Details" asp-route-id="@p.proId" class="card-producto-link">

                    <div class="imagen-card">
                        @* Resolución de la ruta del recurso visual del producto. *@
                        @{
                            string imagePath = ImageHelper.FormatearRuta(p.proImagen);
                        }
                        <img src="@Url.Content(imagePath)" alt="Imagen de @p.proNombre" />
                    </div>

                    <div class="contenido-card">
                        <h5 class="titulo">@p.proNombre</h5>
                        <p class="precio">$@p.proPrecio.ToString("N2")</p>
                    </div>
                </a>
            </div>
        }
    }
    else
    {
        <p class="text-white">No hay productos disponibles en esta categoría.</p>
    }
</section>

<script>
    @* Gestión de visibilidad del menú de filtros dinámicos. *@
    function toggleMenu() {
        var menu = document.getElementById("menu-filtros");
        menu.classList.toggle("oculto");
    }
</script>

