@model Drippin.Models.Categoria
@* Vista retornada por: CategoriasController.Create *@

@{
    ViewData["Title"] = "Crear Categoría";
}

<style>
    th {
        color: white;
    }

    td {
        color: white;
    }

    h1 {
        color: white;
    }

    div {
        color: white;
    }
</style>

<h1>Crear Nueva Categoría</h1>

<h4>Definición de Categoría</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            @* Resumen de errores de validación de modelo capturados en el servidor. *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="CatNombre" class="control-label"></label>
                <input asp-for="CatNombre" class="form-control" />
                <span asp-validation-for="CatNombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CatICO" class="control-label"></label>
                <input asp-for="CatICO" class="form-control" />
                <span asp-validation-for="CatICO" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
</div>

@section Scripts {
    @* Inyección de scripts para la validación asíncrona en el cliente. *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
