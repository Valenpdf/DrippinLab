@model Drippin.Models.Usuario
@* Vista retornada por: UsuariosController.Delete *@

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<style>
    th {
        color: white;
    }

    td {
        color: white;
    }

    h1 {
        color: white;
    }

    div {
        color: white;
    }
</style>

<h1>Eliminar Registro de Usuario</h1>

<h3 class="text-white">¿Está seguro de que desea proceder con la baja definitiva de esta cuenta?</h3>
<div class="text-white">
    <h4>Detalles del Perfil</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UsNombre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UsNombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UsCorreo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UsCorreo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdRol)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdRol)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaRegistro)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaRegistro)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        @* Persistencia del identificador único para la ejecución de la eliminación en el servidor. *@
        <input type="hidden" asp-for="IdUsuario" />
        <input type="submit" value="Confirmar Eliminación" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
    </form>
</div>
