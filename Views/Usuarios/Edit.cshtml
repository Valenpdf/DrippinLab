@model Drippin.Models.Usuario
@* Vista retornada por: UsuariosController.Edit *@

@{
    ViewData["Title"] = "Editar Usuario";
}

<style>
    th {
        color: white;
    }

    td {
        color: white;
    }

    h1 {
        color: white;
    }

    div {
        color: white;
    }
</style>

<h1>Modificar Usuario</h1>

<h4 class="text-white">Actualización de Perfil de Identidad</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            @* Proyección de errores de validación de modelo capturados en el servidor. *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @* Persistencia del identificador único del usuario para la ejecución de la actualización. *@
            <input type="hidden" asp-for="IdUsuario" />

            <div class="form-group mb-2">
                <label asp-for="UsNombre" class="control-label"></label>
                <input asp-for="UsNombre" class="form-control" />
                <span asp-validation-for="UsNombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="UsCorreo" class="control-label"></label>
                <input asp-for="UsCorreo" class="form-control" />
                <span asp-validation-for="UsCorreo" class="text-danger"></span>
            </div>

            @* Gestión de credenciales (Hash de contraseña). *@
            <div class="form-group mb-2">
                <label asp-for="PasswordHash" class="control-label"></label>
                <input asp-for="PasswordHash" class="form-control" type="password" />
                <span asp-validation-for="PasswordHash" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="IdRol" class="control-label"></label>
                <select asp-for="IdRol" class="form-control" asp-items="ViewBag.IdRol">
                    <option value="">-- Seleccionar Rol --</option>
                </select>
                <span asp-validation-for="IdRol" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="FechaRegistro" class="control-label"></label>
                <input asp-for="FechaRegistro" class="form-control" readonly />
                <span asp-validation-for="FechaRegistro" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
</div>

@section Scripts {
    @* Inyección de recursos para la validación asíncrona de formularios en el cliente. *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
