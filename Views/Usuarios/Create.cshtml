@model Drippin.Models.Usuario

@{
    ViewData["Title"] = "Create";
}

<style>

    th {
        color: white;
    }

    td {
        color: white;
    }

    h1 {
        color: white;
    }

    div {
        color: white;
    }

</style>

<h1>Crear Usuario</h1>

<h4>Usuario</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            

            <div class="form-group">
                <label asp-for="UsNombre" class="control-label"></label>
                <input asp-for="UsNombre" class="form-control" />
                <span asp-validation-for="UsNombre" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="UsApellido" class="control-label"></label> @* Asumo que tienes Apellido en tu modelo*@
                <input asp-for="UsApellido" class="form-control" />
                <span asp-validation-for="UsApellido" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="UsCorreo" class="control-label"></label>
                <input asp-for="UsCorreo" class="form-control" />
                <span asp-validation-for="UsCorreo" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="PasswordHash" class="control-label"></label>
                <input asp-for="PasswordHash" class="form-control" type="password" /> 
                <span asp-validation-for="PasswordHash" class="text-danger"></span>
            </div>
            
            @* Usando SelectList de ViewBag (ViewData) *@
            <div class="form-group">
                <label asp-for="IdRol" class="control-label"></label>
                <select asp-for="IdRol" class="form-control" asp-items="ViewBag.IdRol">
                    <option value="">-- Seleccionar Rol --</option>
                </select>
                <span asp-validation-for="IdRol" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver a la Lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}