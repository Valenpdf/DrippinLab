@model Drippin.Models.Role
@* Vista retornada por: RolesController.Edit *@

@{
    ViewData["Title"] = "Editar Rol";
}

<h1 class="text-white">Modificar Rol de Usuario</h1>

<h4 class="text-white">Actualización de Perfil de Seguridad</h4>
<hr class="text-white" />
<div class="row text-white">
    <div class="col-md-4">
        <form asp-action="Edit">
            @* Proyección de errores de validación de modelo capturados en el servidor. *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @* Persistencia del identificador único del rol para la ejecución de la actualización. *@
            <input type="hidden" asp-for="IdRol" />

            <div class="form-group mb-3">
                <label asp-for="NombreRol" class="control-label"></label>
                <input asp-for="NombreRol" class="form-control" />
                <span asp-validation-for="NombreRol" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
</div>

@section Scripts {
    @* Inyección de recursos para la validación asíncrona de formularios en el cliente. *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
