@model Drippin.Models.Role
@* Vista retornada por: RolesController.Delete *@

@{
    ViewData["Title"] = "Eliminar Rol";
}

<h1 class="text-white">Eliminar Rol de Usuario</h1>

<h3 class="text-white">¿Está seguro de que desea eliminar este registro de seguridad?</h3>
<div class="text-white">
    <h4>Detalles del Rol</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NombreRol)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NombreRol)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        @* Persistencia del identificador único para la ejecución de la baja definitiva en el sistema. *@
        <input type="hidden" asp-for="IdRol" />
        <input type="submit" value="Confirmar Eliminación" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
    </form>
</div>
