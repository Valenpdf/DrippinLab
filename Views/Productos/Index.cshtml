@model IEnumerable<Drippin.Models.Producto>
@* Vista retornada por: ProductosController.Index *@

@{
    ViewData["Title"] = "Gestión de Catálogo - Productos";
}

<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet" href="~/css/adminproductos.css" />

<div class="full-width-panel-wrapper">

    <div class="content-container admin-panel-view">
        <form asp-controller="Productos" asp-action="Index" method="get">
            <div class="header-actions">
                <h1>ADMINISTRACIÓN DE PRODUCTOS</h1>
                <a asp-action="Create" class="btn-primary-drippin">➕ Crear Nuevo Producto</a>
            </div>

            @* Sección de filtrado y búsqueda avanzada de productos. *@
            <div class="search-bar-container">
                @* 
                   Control de selección para filtrado por categoría. 
                   Sincroniza el estado del dropdown con el parámetro categoriaId del controlador. 
                *@
                <select name="categoriaId" class="filter-dropdown">
                    <option value="">Todas las Categorías</option>
                    @if (ViewData["CategoriaId"] is SelectList selectList)
                    {
                            @foreach (var categoria in selectList)
                            {
                                    <option value="@categoria.Value" 
                                            selected="@(categoria.Value == (ViewData["CurrentCategoriaId"]?.ToString()))">
                                        @categoria.Text
                                    </option>
                            }
                    }
                </select>
            
                @* Input de búsqueda de texto libre para coincidencia parcial por nombre de producto. *@
                <input type="text" 
                       name="searchString" 
                       value="@ViewData["CurrentFilter"]" 
                       placeholder="Buscar productos por nombre..." 
                       class="search-input" />
                   
                <button type="submit" class="search-button">
                    <i class="fas fa-search"></i> FILTRAR
                </button>
                <a asp-action="Index" class="clear-search-link">Limpiar Filtros</a>
            </div>
        </form>
    
        <hr/>
    
        @* Grilla de visualización de productos en formato de tarjetas informativas. *@
        <div class="products-grid">
            @* Iteración sobre el modelo para la renderización individual de productos. *@
            @foreach (var item in Model)
            {
                    <div class="product-card">
                        <div class="product-image-container">
                            @* Resolución de la ruta del recurso visual del producto mediante ImageHelper. *@
                            <img src="@Url.Content(ImageHelper.FormatearRuta(item.proImagen))" alt="@item.proNombre" class="product-image"/>
                        </div>
                        <div class="product-details">
                            <h2 class="product-name">@Html.DisplayFor(modelItem => item.proNombre)</h2>
                            <p class="product-price">$ @Html.DisplayFor(modelItem => item.proPrecio)</p>
                            <p class="product-availability">
                                <strong>Disponibilidad:</strong>
                                @* Aplicación condicional de estilos basada en el estado de stock del producto. *@
                                <span class="@(item.Disponible ? "available" : "unavailable")">
                                    @(item.Disponible ? "DISPONIBLE" : "AGOTADO")
                                </span>
                            </p>
                    
                            <div class="card-actions">
                                <a asp-action="Edit" asp-route-id="@item.proId" class="btn-secondary-drippin">EDITAR</a>
                                <a asp-action="Details" asp-route-id="@item.proId" class="btn-secondary-drippin">DETALLES</a>
                                <a asp-action="Delete" asp-route-id="@item.proId" class="btn-delete-drippin">ELIMINAR</a>
                            </div>
                        </div>
                    </div>
            }
        </div>

        @* Notificación de ausencia de resultados tras la aplicación de filtros o carga inicial vacía. *@
        @if (!Model.Any())
        {
                <p class="no-products">No hay productos cargados en el sistema.</p>
        }
    </div>

</div>