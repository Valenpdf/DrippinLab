@model Drippin.DTO.UsuariosDTO
@* Vista retornada por: AccesosController.Registrarse *@

@{
    ViewData["Title"] = "Registro de Nuevo Usuario";
}

<style>
    @* Contenedor principal para el posicionamiento centralizado del formulario de registro. *@
    .register-container {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: -50px;
        padding: 4rem 1rem;
    }

    @* Estructura del cuadro de registro con propiedades de opacidad y sombra para profundidad. *@
    .register-box {
        background-color: #1a1a1a;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
        max-width: 500px;
        width: 100%;
        color: #fff;
    }

    .register-box h1 {
        color: #fff;
        text-align: center;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }
    
    .register-box h4 {
        color: #b0b0b0;
        text-align: center;
        margin-bottom: 2rem;
        font-weight: 400;
        font-size: 1.1rem;
    }

    @* Estilos para los componentes de entrada de datos adaptados a esquemas oscuros. *@
    .register-box .form-control {
        background-color: #333;
        color: #fff;
        border: 1px solid #555;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

    .register-box .form-control:focus {
        background-color: #444;
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
        color: #fff;
    }

    @* Sobrescritura de estilos de validación para asegurar contraste en fondos oscuros. *@
    .register-box .text-danger {
        color: #dc3545 !important;
    }

    @* Configuración estética y estructural del resumen de validación total. *@
    .register-box [asp-validation-summary="All"] {
        color: #dc3545 !important;
        margin-bottom: 1rem;
        background-color: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 8px;
        padding: 1rem;
    }

    .register-box [asp-validation-summary="All"] ul {
        padding-left: 1rem;
        margin-bottom: 0;
    }
    
    .register-box [asp-validation-summary="All"] li {
        list-style-type: disc;
    }

    @* Estilos del control de acción de registro principal. *@
    .register-box .btn-success {
        width: 100%;
        padding: 0.75rem;
        font-weight: 600;
        border-radius: 8px;
    }

    @* Organización de enlaces de navegación secundaria. *@
    .register-box .links-container {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.9rem;
    }

    .register-box .links-container a {
        color: #0d6efd;
        text-decoration: none;
    }

    .register-box .links-container a:hover {
        text-decoration: underline;
    }
    
    /* Etiquetas de formulario */
    .register-box .control-label {
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

</style>

<div class="register-container">
    <div class="register-box">

        <h1>Registro</h1>
        <h4>Crea tu cuenta Drippin</h4>

        <form asp-action="Registrarse">
            @* Proyección integral de errores de validación de modelo detectados. *@
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="row">
                @* Segmento de datos de identidad: Nombre y Apellido. *@
                <div class="col-md-6 mb-3">
                    <div class="form-group">
                        <label asp-for="UsNombre" class="control-label"></label>
                        <input asp-for="UsNombre" class="form-control" />
                        <span asp-validation-for="UsNombre" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-group">
                        <label asp-for="UsApellido" class="control-label"></label>
                        <input asp-for="UsApellido" class="form-control" />
                        <span asp-validation-for="UsApellido" class="text-danger"></span>
                    </div>
                </div>
            </div>

            @* Segmento de credenciales de acceso: Correo y Contraseñas. *@
            <div class="form-group mb-3">
                <label asp-for="UsCorreo" class="control-label"></label>
                <input asp-for="UsCorreo" class="form-control" />
                <span asp-validation-for="UsCorreo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-4">
                <label asp-for="ConfirmarPassword" class="control-label"></label>
                <input asp-for="ConfirmarPassword" class="form-control" />
                <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
            </div>
            
            <div class="form-group mt-3">
                <input type="submit" value="Registrarse" class="btn btn-success" />
            </div>

            <div class="links-container mt-3">
                <a asp-action="Login">¿Ya tenes cuenta? Iniciá sesión</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @* Inyección de recursos para la validación asíncrona de formularios en el cliente. *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}