# Drippin - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database Connection
# =============================================================================
# SQL Server SA password (must meet complexity requirements)
SA_PASSWORD=YourStrong!Passw0rd123

# Connection string (uses SA_PASSWORD above)
CONNECTION_STRINGS__DefaultConnection=Server=localhost;Database=DrippinDB;User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True

# =============================================================================
# Email Configuration (Gmail SMTP)
# =============================================================================
# Gmail App Password (NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
GMAIL_USERNAME=your_email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Email settings (mapped to EmailSettings__)
EMAILSETTINGS__HOST=smtp.gmail.com
EMAILSETTINGS__PORT=587
EMAILSETTINGS__SENDERNAME=Drippin Shop

# =============================================================================
# Application Settings
# =============================================================================
# Environment: Development | Production | Staging
ASPNETCORE_ENVIRONMENT=Development

# Application URL
ASPNETCORE_URLS=http://+:80

# Database port (leave empty to NOT expose to host, set to 1433:1433 to expose)
DB_PORT=

# =============================================================================
# Usage
# =============================================================================
# Local: cp env.example .env && docker-compose up --build
# Production: Set these variables in Dokploy dashboard
#
# Note: ConnectionStrings__* and EmailSettings__* use __ (double underscore)
# to map to nested JSON configuration keys