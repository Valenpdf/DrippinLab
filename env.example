# Drippin - Variables de Entorno
# Copia este archivo a .env y completa tus valores

# =============================================================================
# IMPORTANTE: Estas variables son OBLIGATORIAS
# =============================================================================
# Contraseña SA de SQL Server (debe cumplir requisitos de complejidad)
# Mínimo: 1 mayúscula, 1 minúscula, 1 número, 1 símbolo
# SIN ESTA VARIABLE, LA APLICACIÓN NO ARRANCARÁ
SA_PASSWORD=TuContraseñaSegura123!

# App Password de Gmail (NO tu contraseña normal)
# Crear en: https://myaccount.google.com/apppasswords
# SIN ESTA VARIABLE, LA APLICACIÓN NO ARRANCARÁ
GMAIL_USERNAME=tu_email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Configuración SMTP
EMAILSETTINGS__HOST=smtp.gmail.com
EMAILSETTINGS__PORT=587
EMAILSETTINGS__SENDERNAME=Drippin Shop

# =============================================================================
# Configuración de la Aplicación
# =============================================================================
# Entorno: Development | Production | Staging
ASPNETCORE_ENVIRONMENT=Development

# URL de la aplicación
ASPNETCORE_URLS=http://+:80

# Puerto web (por defecto: 5000)
WEB_PORT=5000

# Puerto de base de datos (dejar vacío para NO exponer, o "1433:1433" para exponer)
DB_PORT=

# =============================================================================
# Uso
# =============================================================================
# Local: cp env.example .env && docker-compose up --build
# Producción: Configurar estas variables en el panel de Dokploy
#
# Nota: Las variables ConnectionStrings__* y EmailSettings__* usan __ (doble guión bajo)
# para mapear a las claves de configuración JSON anidadas